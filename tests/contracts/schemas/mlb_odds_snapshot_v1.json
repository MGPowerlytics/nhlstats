{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/mlb_odds_snapshot_v1.json",
  "title": "MLB Odds Snapshot v1",
  "description": "Canonical MLB moneyline odds snapshot row used for ROI and CLV evidence.",
  "type": "object",
  "required": [
    "schema_version",
    "sport",
    "payload_kind",
    "source",
    "source_event_id",
    "game_id",
    "home_team",
    "away_team",
    "commence_time",
    "source_snapshot_at",
    "snapshot_type",
    "bookmaker_key",
    "market_key",
    "outcome_name",
    "outcome_role",
    "decimal_price",
    "implied_probability"
  ],
  "properties": {
    "schema_version": {"const": "v1"},
    "sport": {"const": "MLB"},
    "payload_kind": {"const": "odds_snapshot"},
    "source": {"type": "string", "enum": ["the_odds_api", "princeton_historical_sports_odds", "github_sportsbookreview_mlb_odds"]},
    "source_event_id": {"type": "string", "minLength": 1},
    "game_id": {"type": "string", "minLength": 1},
    "home_team": {"type": "string", "minLength": 1},
    "away_team": {"type": "string", "minLength": 1},
    "commence_time": {"type": "string", "format": "date-time"},
    "requested_snapshot_at": {"type": ["string", "null"], "format": "date-time"},
    "source_snapshot_at": {"type": "string", "format": "date-time"},
    "previous_snapshot_at": {"type": ["string", "null"], "format": "date-time"},
    "next_snapshot_at": {"type": ["string", "null"], "format": "date-time"},
    "snapshot_type": {"type": "string", "enum": ["open", "close", "intraday"]},
    "bookmaker_key": {"type": "string", "minLength": 1},
    "bookmaker_title": {"type": ["string", "null"]},
    "market_key": {"type": "string", "enum": ["h2h"]},
    "outcome_name": {"type": "string", "minLength": 1},
    "outcome_role": {"type": "string", "enum": ["home", "away", "unknown"]},
    "decimal_price": {"type": "number", "exclusiveMinimum": 1.0},
    "implied_probability": {"type": "number", "exclusiveMinimum": 0.0, "exclusiveMaximum": 1.0},
    "is_pregame": {"type": "boolean"},
    "raw_payload": {"type": ["object", "null"]}
  },
  "additionalProperties": false
}
