{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/dashboard_tennis_predictions_v1.schema.json",
  "title": "Dashboard Tennis Predictions Read Model v1",
  "description": "Canonical row contract for actionable TENNIS predictions shown on the dashboard.",
  "version": "v1",
  "type": "object",
  "required": [
    "bet_id",
    "sport",
    "recommendation_date",
    "commence_time",
    "home_team",
    "away_team",
    "bet_on",
    "ticker",
    "model_prob",
    "market_prob",
    "edge",
    "expected_value",
    "kelly_fraction",
    "confidence",
    "yes_ask",
    "no_ask",
    "created_at"
  ],
  "properties": {
    "bet_id": {"type": "string", "pattern": "^TENNIS_[0-9]{4}-[0-9]{2}-[0-9]{2}_.+_(home|away)$"},
    "sport": {"const": "TENNIS"},
    "recommendation_date": {"type": "string", "format": "date"},
    "commence_time": {"type": ["string", "null"], "format": "date-time"},
    "home_team": {"type": "string", "minLength": 1},
    "away_team": {"type": "string", "minLength": 1},
    "bet_on": {"type": "string", "minLength": 1},
    "ticker": {"type": ["string", "null"], "minLength": 1},
    "model_prob": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "market_prob": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "edge": {"type": "number", "minimum": 0.03, "maximum": 0.40},
    "expected_value": {"type": ["number", "null"]},
    "kelly_fraction": {"type": ["number", "null"], "minimum": 0.0},
    "confidence": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
    "yes_ask": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "no_ask": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "created_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "additionalProperties": false
}
