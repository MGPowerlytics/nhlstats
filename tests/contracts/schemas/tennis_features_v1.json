{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/tennis_features_v1.json",
  "title": "Tennis Feature Vector v1",
  "description": "Canonical pre-match Tennis feature payload emitted by TennisFeatureBuilder.",
  "type": "object",
  "required": [
    "schema_version",
    "sport",
    "payload_kind",
    "tour",
    "player_a",
    "player_b",
    "target_surface",
    "match_count_a",
    "match_count_b",
    "weighted_match_count_a",
    "weighted_match_count_b",
    "win_rate_a",
    "win_rate_b",
    "common_opponent_count",
    "common_opponent_win_rate_diff",
    "direct_match_count",
    "direct_win_rate_a",
    "intransitivity_complexity",
    "serve_win_pct_a",
    "serve_win_pct_b",
    "return_win_pct_a",
    "return_win_pct_b",
    "serveadv_a",
    "serveadv_b",
    "complete_a",
    "complete_b",
    "fatigue_a",
    "fatigue_b",
    "fatigue_diff",
    "retired_a",
    "retired_b",
    "age_30_a",
    "age_30_b",
    "rank_a",
    "rank_b",
    "rank_diff",
    "data_certainty"
  ],
  "properties": {
    "schema_version": {"const": "v1"},
    "sport": {"const": "TENNIS"},
    "payload_kind": {"const": "feature_vector"},
    "tour": {"type": "string", "enum": ["ATP", "WTA"]},
    "player_a": {"type": "string", "minLength": 1},
    "player_b": {"type": "string", "minLength": 1},
    "target_surface": {
      "type": "string",
      "enum": ["Hard", "Clay", "Grass", "Carpet", "Unknown"]
    },
    "match_count_a": {"type": "integer", "minimum": 0},
    "match_count_b": {"type": "integer", "minimum": 0},
    "weighted_match_count_a": {"type": "number", "minimum": 0.0},
    "weighted_match_count_b": {"type": "number", "minimum": 0.0},
    "win_rate_a": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "win_rate_b": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "common_opponent_count": {"type": "integer", "minimum": 0},
    "common_opponent_win_rate_diff": {"type": "number", "minimum": -1.0, "maximum": 1.0},
    "direct_match_count": {"type": "integer", "minimum": 0},
    "direct_win_rate_a": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "intransitivity_complexity": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "serve_win_pct_a": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "serve_win_pct_b": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "return_win_pct_a": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "return_win_pct_b": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "serveadv_a": {"type": "number", "minimum": -1.0, "maximum": 1.0},
    "serveadv_b": {"type": "number", "minimum": -1.0, "maximum": 1.0},
    "complete_a": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "complete_b": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "fatigue_a": {"type": "number", "minimum": 0.0},
    "fatigue_b": {"type": "number", "minimum": 0.0},
    "fatigue_diff": {"type": "number"},
    "retired_a": {"type": "integer", "enum": [0, 1]},
    "retired_b": {"type": "integer", "enum": [0, 1]},
    "age_30_a": {"type": "number", "minimum": 0.0},
    "age_30_b": {"type": "number", "minimum": 0.0},
    "rank_a": {"type": ["number", "null"], "exclusiveMinimum": 0.0},
    "rank_b": {"type": ["number", "null"], "exclusiveMinimum": 0.0},
    "rank_diff": {"type": ["number", "null"]},
    "data_certainty": {"type": "number", "minimum": 0.0, "maximum": 1.0}
  },
  "additionalProperties": false
}
