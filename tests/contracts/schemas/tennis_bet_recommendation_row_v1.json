{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/tennis_bet_recommendation_row_v1.json",
  "title": "Tennis Bet Recommendation Contract v1",
  "description": "Canonical TENNIS bet_recommendations persisted-row contract for BetLoader writes through the tennis branch.",
  "$defs": {
    "bet_identifier": {
      "type": "string",
      "description": "Stable hash-shaped TENNIS bet id: TENNIS_<YYYY-MM-DD>_<TICKER>_<side> when ticker is present, or a deterministic synthetic fallback.",
      "pattern": "^TENNIS_[0-9]{4}-[0-9]{2}-[0-9]{2}_[A-Za-z0-9-]+_(home|away)$"
    },
    "ticker_format": {
      "type": "string",
      "pattern": "^KX(ATP|WTA)(CHALLENGER)?MATCH-[A-Z0-9-]+$"
    },
    "base_recommendation": {
      "type": "object",
      "required": [
        "bet_id",
        "sport",
        "recommendation_date",
        "home_team",
        "away_team",
        "bet_on",
        "elo_prob",
        "market_prob",
        "edge",
        "confidence",
        "ticker"
      ],
      "properties": {
        "bet_id": {"$ref": "#/$defs/bet_identifier"},
        "sport": {"const": "TENNIS"},
        "recommendation_date": {"type": "string", "format": "date"},
        "home_team": {"type": "string", "minLength": 1},
        "away_team": {"type": "string", "minLength": 1},
        "bet_on": {"type": "string", "minLength": 1},
        "ticker": {"$ref": "#/$defs/ticker_format"},
        "elo_prob": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "market_prob": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "edge": {"type": "number", "minimum": -0.40, "maximum": 0.40},
        "expected_value": {"type": ["number", "null"]},
        "kelly_fraction": {"type": ["number", "null"], "minimum": 0.0},
        "confidence": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
        "home_rating": {"type": ["number", "null"]},
        "away_rating": {"type": ["number", "null"]},
        "yes_ask": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
        "no_ask": {"type": ["integer", "null"], "minimum": 0, "maximum": 100}
      }
    },
    "saved_payload": {
      "allOf": [
        {"$ref": "#/$defs/base_recommendation"},
        {
          "type": "object",
          "required": ["side"],
          "properties": {
            "side": {"type": "string", "enum": ["home", "away"]}
          }
        }
      ]
    },
    "persisted_row": {
      "allOf": [
        {"$ref": "#/$defs/base_recommendation"}
      ]
    }
  }
}
