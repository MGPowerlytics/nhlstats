{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/mlb_bet_opportunity_v1.json",
  "title": "MLB Bet Opportunity v1",
  "description": "Canonical MLB opportunity payload produced by OddsComparator.find_opportunities for the MLB path. Wave-2 consumer-red contract.",
  "type": "object",
  "required": [
    "sport",
    "game_id",
    "home_team",
    "away_team",
    "side",
    "elo_prob",
    "market_prob",
    "edge",
    "confidence"
  ],
  "properties": {
    "sport": {
      "const": "MLB"
    },
    "game_id": {
      "type": "string",
      "minLength": 1
    },
    "home_team": {
      "type": "string",
      "minLength": 1
    },
    "away_team": {
      "type": "string",
      "minLength": 1
    },
    "side": {
      "type": "string",
      "enum": ["home", "away"]
    },
    "bet_on": {
      "type": "string",
      "minLength": 1
    },
    "elo_prob": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "market_prob": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "market_odds": {
      "type": "number",
      "exclusiveMinimum": 1.0
    },
    "bookmaker": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "edge": {
      "type": "number",
      "minimum": 0.03,
      "maximum": 0.40
    },
    "expected_value": {
      "type": ["number", "null"]
    },
    "kelly_fraction": {
      "type": ["number", "null"],
      "minimum": 0.0
    },
    "sharp_confirmed": {
      "type": "boolean"
    },
    "confidence": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"]
    },
    "agreement_diff": {
      "type": "number",
      "minimum": 0.0
    },
    "home_rating": {
      "type": ["number", "null"]
    },
    "away_rating": {
      "type": ["number", "null"]
    }
  },
  "additionalProperties": false
}
