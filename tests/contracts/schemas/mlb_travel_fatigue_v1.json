{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/mlb_travel_fatigue_v1.json",
  "title": "MLB Travel and Fatigue Features v1",
  "type": "object",
  "required": [
    "schema_version",
    "sport",
    "payload_kind",
    "game_id",
    "team",
    "is_home",
    "time_zones_crossed",
    "travel_direction",
    "west_to_east_penalty",
    "circadian_advantage_hours",
    "days_rest",
    "source",
    "feature_version"
  ],
  "properties": {
    "schema_version": {"const": "v1"},
    "sport": {"const": "MLB"},
    "payload_kind": {"const": "travel_fatigue_features"},
    "game_id": {"type": "string", "minLength": 1},
    "team": {"type": "string", "minLength": 1},
    "is_home": {"type": "boolean"},
    "previous_game_id": {"type": ["string", "null"]},
    "previous_game_date": {"type": ["string", "null"], "format": "date"},
    "previous_venue": {"type": ["string", "null"]},
    "time_zones_crossed": {"type": "integer", "minimum": 0},
    "travel_direction": {"type": "string", "enum": ["none", "east", "west", "north_south", "unknown"]},
    "west_to_east_penalty": {"type": "number", "maximum": 0.0},
    "circadian_advantage_hours": {"type": "number"},
    "local_start_time": {"type": ["string", "null"], "pattern": "^[0-2][0-9]:[0-5][0-9](:[0-5][0-9])?$"},
    "days_rest": {"type": "integer", "minimum": 0, "maximum": 7},
    "source": {"type": "string", "minLength": 1},
    "feature_version": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
