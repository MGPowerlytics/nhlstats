{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/epl_bet_recommendation_row_v1.json",
  "title": "EPL Bet Recommendation Contract v1",
  "description": "Canonical EPL recommendation payload and persisted-row contract for BetLoader and bet_recommendations.",
  "$defs": {
    "bet_identifier": {
      "type": "string",
      "pattern": "^EPL-[0-9]{4}-[0-9]{2}-[0-9]{2}-[A-Z0-9-]+-(home|away|draw)$"
    },
    "base_recommendation": {
      "type": "object",
      "required": [
        "bet_id",
        "sport",
        "recommendation_date",
        "home_team",
        "away_team",
        "bet_on",
        "elo_prob",
        "market_prob",
        "edge",
        "confidence"
      ],
      "properties": {
        "bet_id": {
          "$ref": "#/$defs/bet_identifier"
        },
        "sport": {
          "const": "EPL"
        },
        "recommendation_date": {
          "type": "string",
          "format": "date"
        },
        "home_team": {
          "type": "string",
          "minLength": 1
        },
        "away_team": {
          "type": "string",
          "minLength": 1
        },
        "bet_on": {
          "type": "string",
          "enum": [
            "home",
            "away",
            "draw"
          ]
        },
        "ticker": {
          "type": [
            "string",
            "null"
          ]
        },
        "elo_prob": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "market_prob": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "edge": {
          "type": "number"
        },
        "expected_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "kelly_fraction": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0
        },
        "confidence": {
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW"
          ]
        },
        "home_rating": {
          "type": [
            "number",
            "null"
          ]
        },
        "away_rating": {
          "type": [
            "number",
            "null"
          ]
        },
        "yes_ask": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "no_ask": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "saved_payload": {
      "allOf": [
        {
          "$ref": "#/$defs/base_recommendation"
        },
        {
          "type": "object",
          "required": [
            "side"
          ],
          "properties": {
            "side": {
              "type": "string",
              "enum": [
                "home",
                "away",
                "draw"
              ]
            }
          }
        }
      ]
    },
    "persisted_row": {
      "allOf": [
        {
          "$ref": "#/$defs/base_recommendation"
        }
      ]
    }
  }
}
