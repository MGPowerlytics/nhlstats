{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/tennis_kalshi_market_v1.json",
  "title": "Tennis Kalshi Market Contract v1",
  "description": "Canonical Tennis Kalshi raw single-sided market and persisted game_odds row. Tennis Kalshi exposes one binary per player; pairing happens by event_ticker.",
  "$defs": {
    "ticker": {
      "type": "string",
      "description": "Kalshi tennis market ticker. Series prefix KX(ATP|WTA)(CHALLENGER)?MATCH, alphanumeric date YYMMMDD, six-char compact players code, then 3-char side code.",
      "pattern": "^KX(ATP|WTA)(CHALLENGER)?MATCH-[0-9]{2}[A-Z]{3}[0-9]{2}[A-Z]{6}-[A-Z]{3}$"
    },
    "event_ticker": {
      "type": "string",
      "pattern": "^KX(ATP|WTA)(CHALLENGER)?MATCH-[0-9]{2}[A-Z]{3}[0-9]{2}[A-Z]{6}$"
    },
    "side_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "outcome_name": {
      "type": "string",
      "enum": ["home", "away"]
    },
    "game_id": {
      "type": "string",
      "pattern": "^TENNIS_(ATP|WTA)_[0-9]{4}-[0-9]{2}-[0-9]{2}_[A-Za-z0-9]+_[A-Za-z0-9]+$"
    },
    "raw_market": {
      "type": "object",
      "required": ["ticker", "event_ticker", "yes_sub_title", "title", "yes_ask", "close_time"],
      "properties": {
        "ticker": {"$ref": "#/$defs/ticker"},
        "event_ticker": {"$ref": "#/$defs/event_ticker"},
        "yes_sub_title": {"type": "string", "minLength": 1},
        "no_sub_title": {"type": ["string", "null"]},
        "title": {"type": "string", "minLength": 1},
        "yes_ask": {"type": "integer", "minimum": 1, "maximum": 99},
        "no_ask": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
        "close_time": {"type": "string"},
        "status": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "game_odds_row": {
      "type": "object",
      "required": [
        "odds_id",
        "game_id",
        "bookmaker",
        "market_name",
        "outcome_name",
        "price",
        "is_pregame",
        "external_id"
      ],
      "properties": {
        "odds_id": {
          "type": "string",
          "pattern": "^TENNIS_(ATP|WTA)_[0-9]{4}-[0-9]{2}-[0-9]{2}_[A-Za-z0-9]+_[A-Za-z0-9]+_kalshi_(home|away)$"
        },
        "game_id": {"$ref": "#/$defs/game_id"},
        "bookmaker": {"const": "Kalshi"},
        "market_name": {"const": "moneyline"},
        "outcome_name": {"$ref": "#/$defs/outcome_name"},
        "price": {"type": "number", "exclusiveMinimum": 1.0},
        "is_pregame": {"const": true},
        "external_id": {"$ref": "#/$defs/ticker"}
      },
      "additionalProperties": false
    }
  }
}
