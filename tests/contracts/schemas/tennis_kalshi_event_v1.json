{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/tennis_kalshi_event_v1.json",
  "title": "Tennis Kalshi Event Aggregation Contract v1",
  "description": "Aggregated paired event produced by _save_tennis_kalshi_markets. Captures the event-level metadata plus the unified_games row and the two game_odds rows persisted for a matchup.",
  "$defs": {
    "side_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "tour": {
      "type": "string",
      "enum": ["ATP", "WTA"]
    },
    "game_id": {
      "type": "string",
      "pattern": "^TENNIS_(ATP|WTA)_[0-9]{4}-[0-9]{2}-[0-9]{2}_[A-Za-z0-9]+_[A-Za-z0-9]+$"
    },
    "unified_game": {
      "type": "object",
      "required": [
        "game_id",
        "sport",
        "game_date",
        "home_team_name",
        "away_team_name"
      ],
      "properties": {
        "game_id": {"$ref": "#/$defs/game_id"},
        "sport": {"const": "TENNIS"},
        "game_date": {"type": "string", "format": "date"},
        "home_team_name": {"type": "string", "minLength": 1},
        "away_team_name": {"type": "string", "minLength": 1},
        "home_team_id": {"type": ["string", "null"]},
        "away_team_id": {"type": ["string", "null"]},
        "commence_time": {"type": ["string", "null"]},
        "status": {"type": "string", "enum": ["Scheduled", "Final"]}
      },
      "additionalProperties": false
    },
    "game_odds_row": {
      "type": "object",
      "required": [
        "odds_id",
        "game_id",
        "outcome_name",
        "price",
        "external_id"
      ],
      "properties": {
        "odds_id": {
          "type": "string",
          "pattern": "^TENNIS_(ATP|WTA)_[0-9]{4}-[0-9]{2}-[0-9]{2}_[A-Za-z0-9]+_[A-Za-z0-9]+_kalshi_(home|away)$"
        },
        "game_id": {"$ref": "#/$defs/game_id"},
        "outcome_name": {"type": "string", "enum": ["home", "away"]},
        "price": {"type": "number", "exclusiveMinimum": 1.0},
        "external_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "paired_event": {
      "type": "object",
      "required": [
        "event_ticker",
        "tour",
        "game_date",
        "home_side_code",
        "away_side_code",
        "home_player_full_name",
        "away_player_full_name",
        "game_id",
        "unified_game",
        "game_odds"
      ],
      "properties": {
        "event_ticker": {
          "type": "string",
          "pattern": "^KX(ATP|WTA)(CHALLENGER)?MATCH-[0-9]{2}[A-Z]{3}[0-9]{2}[A-Z]{6}$"
        },
        "tour": {"$ref": "#/$defs/tour"},
        "game_date": {"type": "string", "format": "date"},
        "home_side_code": {"$ref": "#/$defs/side_code"},
        "away_side_code": {"$ref": "#/$defs/side_code"},
        "home_player_full_name": {"type": "string", "minLength": 1},
        "away_player_full_name": {"type": "string", "minLength": 1},
        "game_id": {"$ref": "#/$defs/game_id"},
        "unified_game": {"$ref": "#/$defs/unified_game"},
        "game_odds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {"$ref": "#/$defs/game_odds_row"}
        }
      },
      "additionalProperties": false
    }
  }
}
