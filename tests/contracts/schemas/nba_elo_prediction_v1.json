{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NBA Elo Prediction v1",
  "type": "object",
  "required": [
    "schema_version",
    "sport",
    "payload_kind",
    "home_team",
    "away_team",
    "home_rating",
    "away_rating",
    "home_prob"
  ],
  "properties": {
    "schema_version": {"const": "v1"},
    "sport": {"const": "NBA"},
    "payload_kind": {"const": "elo_prediction"},
    "home_team": {"type": "string", "minLength": 1},
    "away_team": {"type": "string", "minLength": 1},
    "home_rating": {"type": "number", "exclusiveMinimum": 0},
    "away_rating": {"type": "number", "exclusiveMinimum": 0},
    "home_prob": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "home_advantage": {"type": "number", "minimum": 0.0},
    "k_factor": {"type": "number", "exclusiveMinimum": 0.0},
    "is_neutral": {"type": "boolean"}
  },
  "additionalProperties": false
}
