{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/kalshi_order_payload_v1.json",
  "title": "Kalshi Order Payload Contract v1",
  "description": "Canonical Kalshi order payload schema for orders from /portfolio/orders.",
  "type": "object",
  "required": [
    "order_id",
    "client_order_id",
    "ticker",
    "side",
    "status",
    "fill_count_fp",
    "initial_count_fp",
    "yes_price",
    "yes_price_dollars",
    "no_price",
    "no_price_dollars",
    "taker_fill_cost_dollars",
    "taker_fees_dollars",
    "created_time"
  ],
  "properties": {
    "order_id": {
      "type": "string",
      "minLength": 1,
      "description": "Kalshi order identifier"
    },
    "client_order_id": {
      "type": "string",
      "minLength": 1,
      "description": "Client-generated order identifier (UUID)"
    },
    "ticker": {
      "type": "string",
      "minLength": 1,
      "description": "Kalshi market ticker"
    },
    "side": {
      "type": "string",
      "enum": ["yes", "no"],
      "description": "Side of the order"
    },
    "status": {
      "type": "string",
      "enum": ["executed", "resting", "canceled", "cancelled"],
      "description": "Order status"
    },
    "fill_count_fp": {
      "type": "number",
      "minimum": 0.0,
      "description": "Number of contracts filled (floating-point)"
    },
    "initial_count_fp": {
      "type": "number",
      "exclusiveMinimum": 0.0,
      "description": "Initial order size (floating-point)"
    },
    "yes_price": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "YES price in cents"
    },
    "yes_price_dollars": {
      "type": "string",
      "pattern": "^\\d+\\.\\d{2}$",
      "description": "YES price in dollar string form"
    },
    "no_price": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "NO price in cents"
    },
    "no_price_dollars": {
      "type": "string",
      "pattern": "^\\d+\\.\\d{2}$",
      "description": "NO price in dollar string form"
    },
    "taker_fill_cost_dollars": {
      "type": "string",
      "pattern": "^-?\\d+\\.\\d{2}$",
      "description": "Total fill cost in dollar string form"
    },
    "taker_fees_dollars": {
      "type": "string",
      "pattern": "^-?\\d+\\.\\d{2}$",
      "description": "Total fees in dollar string form"
    },
    "created_time": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of order creation"
    }
  },
  "additionalProperties": false
}
