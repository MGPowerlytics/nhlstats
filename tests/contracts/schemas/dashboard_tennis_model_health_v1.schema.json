{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tests/contracts/schemas/dashboard_tennis_model_health_v1.schema.json",
  "title": "Dashboard Tennis Model Health v1",
  "type": "object",
  "required": [
    "run_date",
    "model_version",
    "data_source",
    "rows",
    "holdout_rows",
    "betmgm_holdout_rows",
    "enabled",
    "beats_betmgm",
    "baseline_log_loss",
    "ensemble_log_loss",
    "ensemble_market_log_loss",
    "betmgm_log_loss",
    "baseline_brier",
    "ensemble_brier",
    "ensemble_market_brier",
    "betmgm_brier",
    "baseline_accuracy",
    "ensemble_accuracy",
    "ensemble_market_accuracy",
    "betmgm_accuracy",
    "baseline_actionable_count",
    "ensemble_actionable_count",
    "log_loss_delta",
    "brier_delta",
    "accuracy_delta",
    "ensemble_vs_betmgm_log_loss_delta",
    "ensemble_vs_betmgm_brier_delta",
    "ensemble_vs_betmgm_accuracy_delta",
    "created_at"
  ],
  "properties": {
    "run_date": {"type": "string", "format": "date"},
    "model_version": {"type": "string", "minLength": 1},
    "data_source": {"type": "string", "minLength": 1},
    "rows": {"type": "integer", "minimum": 0},
    "holdout_rows": {"type": "integer", "minimum": 0},
    "betmgm_holdout_rows": {"type": "integer", "minimum": 0},
    "enabled": {"type": "boolean"},
    "beats_betmgm": {"type": "boolean"},
    "baseline_log_loss": {"type": "number", "minimum": 0.0},
    "ensemble_log_loss": {"type": "number", "minimum": 0.0},
    "ensemble_market_log_loss": {"type": ["number", "null"], "minimum": 0.0},
    "betmgm_log_loss": {"type": ["number", "null"], "minimum": 0.0},
    "baseline_brier": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "ensemble_brier": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "ensemble_market_brier": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
    "betmgm_brier": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
    "baseline_accuracy": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "ensemble_accuracy": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "ensemble_market_accuracy": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
    "betmgm_accuracy": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
    "baseline_actionable_count": {"type": "integer", "minimum": 0},
    "ensemble_actionable_count": {"type": "integer", "minimum": 0},
    "log_loss_delta": {"type": "number"},
    "brier_delta": {"type": "number"},
    "accuracy_delta": {"type": "number"},
    "ensemble_vs_betmgm_log_loss_delta": {"type": ["number", "null"]},
    "ensemble_vs_betmgm_brier_delta": {"type": ["number", "null"]},
    "ensemble_vs_betmgm_accuracy_delta": {"type": ["number", "null"]},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
