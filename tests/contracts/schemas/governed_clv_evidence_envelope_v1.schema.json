      "type": [
        "string",
        "null"
      ]
    },
    "linked_selection_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "clv_source_type": {
      "type": "string",
      "enum": [
        "market_close",
        "binary_result_placeholder",
        "missing_close",
        "unlinked_close"
      ]
    },
    "clv_computed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "entry_probability": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "entry_price_role": {
      "type": "string",
      "enum": [
        "executable"
      ]
    },
    "closing_probability": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "clv_delta": {
      "type": [
        "number",
        "null"
      ]
    },
    "clv_direction": {
      "type": "string",
      "enum": [
        "positive",
        "negative",
        "flat"
      ]
    },
    "closing_quote_source": {
      "type": "string",
      "minLength": 1
    },
    "closing_quote_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "close_price_role": {
      "type": "string",
      "enum": [
        "close",
        "descriptive_placeholder"
      ]
    },
    "close_freshness_result": {
      "type": "string",
      "enum": [
        "fresh",
        "stale",
        "missing_source_timestamp",
        "missing_close"
      ]
