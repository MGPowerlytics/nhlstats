# Runtime environment template.
# Inject real values from your environment or secret manager; do not commit populated secrets.

# Image/runtime configuration
AIRFLOW_IMAGE_NAME=nhlstats-airflow:local
AIRFLOW_UID=50000

# Optional Airflow bootstrap admin
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=change-me

# Optional SMTP configuration
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Required Kalshi runtime credentials
KALSHI_API_KEY_ID=your-kalshi-api-key-id
ODDS_API_KEY=your-odds-api-key

# Required compose secret source on the host; must point to a non-empty PEM private key file
KALSHI_PRIVATE_KEY_FILE=/absolute/path/to/kalshi_private_key.pem

# Canonical in-container secret path consumed by the app
KALSHI_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem
